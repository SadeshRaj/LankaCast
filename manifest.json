{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.1.0",
  "description": "__MSG_extensionDesc__",
  "default_locale": "en",
  "permissions": [
    "alarms",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "http://www.adaderana.lk/*",
    "https://www.adaderana.lk/*",
    "https://sinhala.adaderana.lk/*",
    "https://adaderana.lk/*",
    "https://ada-derana-prod-english-news-temp.s3.amazonaws.com/*",
    "https://adaderanatamil.lk/*",
    "https://www.adaderanatamil.lk/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/SL128.png",
      "48": "images/SL128.png",
      "128": "images/LankaCast.png"
    }
  },
  "icons": {
    "16": "images/SL128.png",
    "48": "images/LankaCast.png",
    "128": "images/LankaCast.png"
  }
}